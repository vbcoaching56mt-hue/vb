{
  "buildCommand": "cd vb-logiciel && npm run build",
  "outputDirectory": "vb-logiciel/build",
  "installCommand": "npm install && cd vb-logiciel && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/automation/process",
      "schedule": "0 8 * * *"
    }
  ]
}
